{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@devradar/types": ["packages/types/src/index.ts"],
      "@devradar/utils": ["packages/utils/src/index.ts"],
      "@devradar/ui": ["packages/ui/src/index.ts"],
      "@devradar/config/*": ["packages/config/*"]
    }
  }
}
